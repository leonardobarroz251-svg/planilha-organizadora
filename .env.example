# Cofre — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase.

# Obrigatórios — em https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://<seu-projeto>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<sua-anon-key>"

# Opcional — usado pelo OAuth/magic-link callback e por links absolutos em emails.
# Em produção, defina para o domínio final (ex: https://cofre.app).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
