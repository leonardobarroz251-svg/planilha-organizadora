# Cofre — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase.

# Obrigatórios — em https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://<seu-projeto>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<sua-anon-key>"

# Opcional — usado pelo OAuth/magic-link callback e por links absolutos em emails.
# Em produção, defina para o domínio final (ex: https://cofre.app).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Resend (SMTP customizado para o Supabase Auth, dev local)
# Gere em https://resend.com/api-keys
SUPABASE_AUTH_SMTP_PASS="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Supabase service role (server-side only — NUNCA commitar).
# Em https://supabase.com/dashboard/project/<ref>/settings/api-keys
# Usada por server actions admin (convidar usuário, definir role).
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role..."
